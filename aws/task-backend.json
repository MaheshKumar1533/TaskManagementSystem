{
  "family": "tasksphere-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::437659978187:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::437659978187:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "437659978187.dkr.ecr.us-east-1.amazonaws.com/tasksphere-backend:latest",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_HOST",
          "value": "tasksphere-db.cwbwkge4ighi.us-east-1.rds.amazonaws.com"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "tasksphere"
        },
        {
          "name": "DB_USER",
          "value": "postgres"
        },
        {
          "name": "DB_PASSWORD",
          "value": "admin123"
        },
        {
          "name": "DEBUG",
          "value": "False"
        },
        {
          "name": "SECRET_KEY",
          "value": "5+58%ykt+ic8$zbxmd7ip%t2h1jfhj%wcmwlhdzq^^6v_uawl-"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tasksphere",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
