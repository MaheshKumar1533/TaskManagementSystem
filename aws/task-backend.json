{
  "family": "tasksphere-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "BACKEND_IMAGE_PLACEHOLDER",
      "cpu": 256,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "DB_HOST",
          "value": "DB_HOST_PLACEHOLDER"
        },
        {
          "name": "DB_PORT",
          "value": "DB_PORT_PLACEHOLDER"
        },
        {
          "name": "DB_NAME",
          "value": "DB_NAME_PLACEHOLDER"
        },
        {
          "name": "DB_USER",
          "value": "DB_USER_PLACEHOLDER"
        },
        {
          "name": "DB_PASSWORD",
          "value": "DB_PASSWORD_PLACEHOLDER"
        },
        {
          "name": "DEBUG",
          "value": "False"
        },
        {
          "name": "SECRET_KEY",
          "value": "SECRET_KEY_PLACEHOLDER"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/tasksphere",
          "awslogs-region": "AWS_REGION_PLACEHOLDER",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
