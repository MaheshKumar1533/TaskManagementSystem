# =====================================================================
# TaskSphere Central Configuration Template
# Copy this file to .env and replace placeholders with active credentials
# =====================================================================

# ---------------------------------------------------------------------
# 1. Local Development Settings (Docker Compose)
# ---------------------------------------------------------------------
LOCAL_DB_NAME=tasksphere
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=postgres
LOCAL_DB_PORT=5432

# ---------------------------------------------------------------------
# 2. AWS Production Settings (Amazon RDS Database)
# ---------------------------------------------------------------------
AWS_RDS_ENDPOINT=your-rds-endpoint.us-east-1.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_DB_NAME=tasksphere
AWS_RDS_USER=postgres
AWS_RDS_PASSWORD=your-secure-rds-password

# ---------------------------------------------------------------------
# 3. AWS Deployments Configurations
# ---------------------------------------------------------------------
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1
ECS_CLUSTER=tasksphere-cluster
ECS_SERVICE_BACKEND=tasksphere-backend
ECS_SERVICE_FRONTEND=tasksphere-frontend

# ---------------------------------------------------------------------
# 4. Application Security Settings
# ---------------------------------------------------------------------
SECRET_KEY=django-insecure-some-random-secret-key-string-value
DEBUG=False
